# ============================================================
# Sistema de Chamados — variáveis de ambiente
# Copie este arquivo como `.env` e preencha os valores reais.
# NUNCA comite `.env` no git.
# ============================================================

# --- Banco Postgres (mesmo cluster do Chatwoot, database separado) ---
# Criar o banco antes: CREATE DATABASE suporte;
DATABASE_URL=postgres://postgres:SENHA@server.fluxodigitaltech.com.br:5440/suporte?sslmode=disable

# --- Redis (mesma instância do Chatwoot) ---
REDIS_URL=redis://default:SENHA@server.fluxodigitaltech.com.br:6379
REDIS_PASSWORD=SENHA

# --- NextAuth ---
# Gerar com:  openssl rand -base64 32
NEXTAUTH_SECRET=troque-isso-em-producao
NEXTAUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# --- Admin inicial (usado apenas no seed) ---
INITIAL_ADMIN_EMAIL=admin@fluxodigitaltech.com.br
INITIAL_ADMIN_PASSWORD=troque-esta-senha
INITIAL_ADMIN_NAME=Administrador Fluxo

# --- Uploads ---
UPLOADS_DIR=./uploads
UPLOADS_MAX_SIZE_MB=10

# --- Aplicação ---
APP_NAME="Fluxo Suporte"
APP_URL=http://localhost:3001
NODE_ENV=development
